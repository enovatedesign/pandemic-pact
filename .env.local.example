# Craft CMS GraphQL API
CONTENT_API_URL="https://pandemic-pact-cms.test/api/"
CONTENT_API_TOKEN=""
REVALIDATE_API_TOKEN=""

# OpenSearch
SEARCH_HOST=""
SEARCH_USERNAME=""
SEARCH_PASSWORD=""
SEARCH_INDEX_PREFIX=""
# Optional version suffix appended to the index name (e.g. "v2" -> "grants-v2").
# Use to build a parallel index with updated mappings, then promote to
# production by setting the same value in the production environment.
SEARCH_INDEX_VERSION=""

# Google Tag Manager
NEXT_PUBLIC_GTM_ID=""

# Development
NODE_TLS_REJECT_UNAUTHORIZED=0
SKIP_OPENSEARCH_INDEXING=true
SKIP_FETCHING_PUBMED_DATA=true

# Grant data storage backend: "blob" (default) or "s3". See docs/aws-s3-setup.md.
STORAGE_BACKEND=blob

# Vercel Blob Storage for Grants (used when STORAGE_BACKEND=blob)
BLOB_READ_WRITE_TOKEN=""
BLOB_BASE_URL="https://b8xcmr4pduujyuoo.public.blob.vercel-storage.com"
USE_BLOB_STORAGE=false
FORCE_BLOB_UPLOAD=false

# Amazon S3 + CloudFront for Grants (used when STORAGE_BACKEND=s3)
AWS_REGION="eu-west-2"
S3_BUCKET="pandemicpact-data"
ASSET_BASE_URL="https://pandemicpact.edcdn.com"  # CloudFront base (custom domain)
CLOUDFRONT_DISTRIBUTION_ID="EWF07XQC5255V"              # for cache invalidation of changed objects
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY via the standard AWS credential chain
FORCE_S3_UPLOAD=false

# FigShare Personal Access Token
FIGSHARE_PA_TOKEN=""
